{
  "name": "sefi-stellar",
  "private": true,
  "version": "1.0.0",
  "description": "Sefi — Stellar protocol semantic layer + Agent SDK (Part 1)",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit || tsc -b",
    "test": "node --import tsx --test \"packages/**/*.test.ts\"",
    "api": "tsx apps/api/src/index.ts",
    "worker": "tsx apps/worker/src/index.ts",
    "demo": "tsx apps/demo-agent/src/index.ts",
    "smoke": "tsx scripts/smoke-test.ts",
    "ingest:blend": "tsx scripts/ingest-blend.ts",
    "ingest:aquarius": "tsx scripts/ingest-aquarius.ts",
    "ingest:sdex": "tsx scripts/ingest-sdex.ts",
    "replay": "tsx scripts/replay.ts",
    "prove:blend": "tsx scripts/prove-blend-utilization.ts",
    "prove:composite": "tsx scripts/prove-composite-borrow-exit.ts",
    "verify:proof": "tsx scripts/verify-proof.ts",
    "demo:phase2": "tsx scripts/demo-phase2.ts",
    "contracts:build": "bash scripts/contracts-build.sh",
    "contracts:test": "bash -c \"export PATH=$HOME/.rustup/toolchains/stable-aarch64-apple-darwin/bin:$PATH; cargo test --manifest-path contracts/sefi_verifier_registry/Cargo.toml && cargo test --manifest-path contracts/noir_ultrahonk_verifier/Cargo.toml\"",
    "deploy:verifier:testnet": "bash scripts/deploy-verifier-testnet.sh",
    "verify:proof:testnet": "tsx scripts/verify-proof-testnet.ts",
    "noir:build": "tsx scripts/noir-build.ts",
    "zk:test": "tsx scripts/zk-test.ts",
    "prove:blend:bn254": "tsx scripts/prove-blend-bn254.ts",
    "prove:composite:bn254": "tsx scripts/prove-composite-bn254.ts",
    "verify:proof:bn254": "tsx scripts/verify-proof-bn254.ts",
    "zk:testnet": "tsx scripts/verify-groth16-testnet.ts",
    "zk:localnet": "tsx scripts/zk-localnet.ts",
    "verify:groth16:testnet": "tsx scripts/verify-groth16-testnet.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@blend-capital/blend-sdk": "3.1.0",
    "@sefi/context-capsules": "workspace:*",
    "@sefi/sdk": "workspace:*",
    "@sefi/semantic-core": "workspace:*",
    "@sefi/shared-types": "workspace:*",
    "@sefi/source-records": "workspace:*",
    "@sefi/stellar-client": "workspace:*",
    "@sefi/store": "workspace:*",
    "@stellar/stellar-sdk": "13.3.0",
    "express": "^4.21.0",
    "pg": "^8.13.0",
    "@sefi/compute": "workspace:*",
    "@sefi/proofs": "workspace:*"
  }
}
