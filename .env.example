# Sefi Stellar — environment (spec §17). Everything is LIVE; there is no mock mode.

# Network selection. Mainnet has the live Blend/Aquarius liquidity used by the demo.
SEFI_NETWORK=mainnet            # testnet | mainnet

# Optional endpoint overrides (sensible defaults are chosen per network)
# SEFI_RPC_URL=https://mainnet.sorobanrpc.com
# SEFI_HORIZON_URL=https://horizon.stellar.org

# Canonical store. If unset, the in-memory store is used (on-demand mode).
# DATABASE_URL=postgres://sefi:sefi@localhost:5432/sefi

# API
PORT=8080

# Aquarius AMM router contract. Defaults to the mainnet router; required on testnet.
# AQUARIUS_ROUTER=CBQDHNBFBZYE4MKPWBSJOPIYLW4SFSXAXUTSXJN76GNKYVYPCKWC6QUK

# Demo / smoke Blend pool (mainnet "Fixed XLM-USDC" pool by default)
# SEFI_DEMO_POOL=CDVQVKOY2YSXS2IC7KN6MNASSHPAO7UN2UR2ON4OI2SKMFJNVAMDX6DP
# SEFI_DEMO_WALLET=G...          # optional, enables live user-position facts

# Worker ingestion targets (background mode)
# SEFI_BLEND_POOLS=CDVQVKOY2YSXS2IC7KN6MNASSHPAO7UN2UR2ON4OI2SKMFJNVAMDX6DP
# SEFI_AQUA_PAIRS=USDC:XLM
# SEFI_SDEX_MARKETS=XLM:USDC

# Optional LLM narration for the demo agent (defaults to the deterministic reasoner)
# SEFI_LLM_API_KEY=sk-ant-...
# SEFI_LLM_MODEL=claude-opus-4-8
